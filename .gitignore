# Assets pesados — não commitar
assets/libras/*.mp4
assets/libras/*.MP4
# assets/pages — imagens commitadas para GitHub Pages servir
assets/audio/*.mp3
assets/audio/*.wav
assets/audio/*.ogg

# Markers AR NFT (fset são grandes, .mind são pequenos e devem ser commitados)
assets/markers/*.fset
assets/markers/*.fset3
assets/markers/*.iset

# Python
__pycache__/
*.pyc

# Variáveis de ambiente
.env
.env.*


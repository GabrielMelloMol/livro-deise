# Assets pesados — regra legada (pasta assets/libras/ vazia; vídeo real é assets/video/*.mp4,
# que PRECISA ser commitado pro GitHub Pages servir — não há LFS aqui)
assets/libras/*.mp4
assets/libras/*.MP4
# assets/pages — imagens commitadas para GitHub Pages servir
# áudios de narração (.mp3) SÃO commitados — pequenos (~600KB total) e necessários no deploy
assets/audio/*.wav
assets/audio/*.ogg

# Markers AR NFT (fset são grandes, .mind são pequenos e devem ser commitados)
assets/markers/*.fset
assets/markers/*.fset3
assets/markers/*.iset

# Node (ferramentas de build dos modelos AR — não vão pro deploy)
node_modules/

# Python
__pycache__/
*.pyc

# Variáveis de ambiente
.env
.env.*

# OS
.DS_Store
Thumbs.db
